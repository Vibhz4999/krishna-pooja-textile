                badge: "Sale"
            }
        ];

        // ===========================================
        // CATEGORY DATA
        // ===========================================
        const categories = [
            {
                name: "Sarees",
                count: "200+ Products",
                image: "https://images.unsplash.com/photo-1610030469983-98e550d6193c?w=500&h=400&fit=crop&q=80"
            },
            {
                name: "Dress Materials",
                count: "150+ Products",
                image: "https://images.unsplash.com/photo-1617627143750-d86bc21e42bb?w=500&h=400&fit=crop&q=80"
            },
            {
                name: "Kurtis",
                count: "100+ Products",
                image: "https://images.unsplash.com/photo-1745313452052-0e4e341f326c?w=500&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8ZGVzaWduZXIlMjBrdXJ0aXxlbnwwfHwwfHx8MA%3D%3D"
            }
        ];

        // ===========================================
        // TESTIMONIAL DATA
        // ===========================================
        const testimonials = [
            {
                name: "Priya Sharma",
                location: "Mumbai",
                text: "Excellent quality sarees! The Banarasi silk I purchased was absolutely beautiful. Great customer service too.",
                rating: 5
            },
            {
                name: "Anjali Patel",
                location: "Ahmedabad",
                text: "I have been buying from Krishna Pooja Textiles for years. Their collection is always fresh and prices are very reasonable.",
                rating: 5
            },
            {
                name: "Meera Reddy",
                location: "Hyderabad",
                text: "The dress material I ordered was exactly as shown. Good quality fabric and fast delivery. Highly recommended!",
                rating: 5
            }
        ];

        // ===========================================
        // RENDER PRODUCTS
        // ===========================================
        function renderProducts() {
            const grid = document.getElementById('productsGrid');
            let html = '';

            // Loop through each product
            for (let i = 0; i < products.length; i++) {
                const product = products[i];
                
                html += `
                    <div class="product-card">
                        <div style="position: relative;">
                            <img src="${product.image}" alt="${product.name}">
                            ${product.badge ? `<span class="product-badge">${product.badge}</span>` : ''}
                        </div>
                        <div class="product-info">
                            <h3 style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">${product.name}</h3>
                            <div>
                                <span style="font-size: 18px; font-weight: 700; color: #8B1538;">Rs. ${product.price}</span>
                                <span style="font-size: 14px; color: #999; text-decoration: line-through; margin-left: 8px;">Rs. ${product.oldPrice}</span>
                            </div>
                        </div>
                    </div>
                `;
            }

            grid.innerHTML = html;
        }

        // ===========================================
        // RENDER CATEGORIES
        // ===========================================
        function renderCategories() {
            const grid = document.getElementById('categoriesGrid');
            let html = '';

            // Loop through each category
            for (let i = 0; i < categories.length; i++) {
                const category = categories[i];
                
                html += `
                    <div class="category-card">
                        <img src="${category.image}" alt="${category.name}">
                        <div class="category-overlay">
                            <h3>${category.name}</h3>
                            <p>${category.count}</p>
                        </div>
                    </div>
                `;
            }

            grid.innerHTML = html;
        }

        // ===========================================
        // RENDER TESTIMONIALS
        // ===========================================
        function renderTestimonials() {
            const grid = document.getElementById('testimonialsGrid');
            let html = '';

            // Loop through each testimonial
            for (let i = 0; i < testimonials.length; i++) {
                const t = testimonials[i];
                
                // Create star icons
                let stars = '';
                for (let j = 0; j < t.rating; j++) {
                    stars += `
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="#D4A853">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                        </svg>
                    `;
                }
                
                html += `
                    <div class="testimonial-card">
                        <div class="stars" style="display: flex; gap: 4px;">
                            ${stars}
                        </div>
                        <p style="color: #6B7280; line-height: 1.7; margin-bottom: 20px; font-style: italic;">"${t.text}"</p>
                        <div>
                            <p style="font-weight: 600; color: #1A1A1A;">${t.name}</p>
                            <p style="font-size: 14px; color: #999;">${t.location}</p>
                        </div>
                    </div>
                `;
            }

            grid.innerHTML = html;
        }

        // ===========================================
        // HEADER SCROLL EFFECT
        // ===========================================
        window.addEventListener('scroll', function() {
            const header = document.getElementById('header');
            
            // Add class when scrolled
            if (window.scrollY > 50) {
                header.classList.add('scrolled');
            } else {
                header.classList.remove('scrolled');
            }
        });

        // ===========================================
        // MOBILE MENU FUNCTIONS
        // ===========================================
        function openMobileMenu() {
            document.getElementById('mobileNav').classList.add('active');
        }

        function closeMobileMenu() {
            document.getElementById('mobileNav').classList.remove('active');
        }

        // ===========================================
        // SMOOTH SCROLL
        // ===========================================
        document.querySelectorAll('a[href^="#"]').forEach(function(link) {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                
                const targetId = this.getAttribute('href');
                const target = document.querySelector(targetId);
                
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

       
        document.getElementById('feedbackForm').addEventListener('submit', function(e) {
e.preventDefault();
alert('Thank you for your feedback!');
this.reset();
});

     
        document.addEventListener('DOMContentLoaded', function() {
            renderProducts();
            renderCategories();
            renderTestimonials();
        });

        function adjustGrids() {
            const productsGrid = document.getElementById('productsGrid');
            const categoriesGrid = document.getElementById('categoriesGrid');
            const testimonialsGrid = document.getElementById('testimonialsGrid');
            
            if (window.innerWidth < 768) {
                // Mobile: 1 column
                productsGrid.style.gridTemplateColumns = '1fr';
                categoriesGrid.style.gridTemplateColumns = '1fr';
                testimonialsGrid.style.gridTemplateColumns = '1fr';
            } else if (window.innerWidth < 1024) {
                // Tablet: 2 columns
                productsGrid.style.gridTemplateColumns = 'repeat(2, 1fr)';
                categoriesGrid.style.gridTemplateColumns = 'repeat(2, 1fr)';
                testimonialsGrid.style.gridTemplateColumns = '1fr';
            } else {
                // Desktop: 4 columns for products, 3 for categories
                productsGrid.style.gridTemplateColumns = 'repeat(4, 1fr)';
                categoriesGrid.style.gridTemplateColumns = 'repeat(3, 1fr)';
                testimonialsGrid.style.gridTemplateColumns = 'repeat(3, 1fr)';
            }
        }

        // Run on load and resize
        window.addEventListener('load', adjustGrids);
        window.addEventListener('resize', adjustGrids);
    </script>

