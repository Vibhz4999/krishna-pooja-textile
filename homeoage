    <!-- ===========================================
         HERO SECTION
         =========================================== -->
    <section class="hero" id="home">
        <div class="container">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">
                
                <!-- Hero Content -->
                <div class="hero-content">
                    <p style="color: var(--gold); font-weight: 600; letter-spacing: 2px; text-transform: uppercase; font-size: 13px; margin-bottom: 15px;">
                        Premium Quality Fabrics
                    </p>
                    <h1 style="font-size: 48px; line-height: 1.2; margin-bottom: 20px;">
                        Exquisite Textiles for <span style="color: var(--primary);">Every Occasion</span>
                    </h1>
                    <p style="color: var(--gray); font-size: 16px; line-height: 1.7; margin-bottom: 30px;">
                        Discover our curated collection of premium sarees, dress materials, and fabrics. 
                        Quality craftsmanship meets timeless elegance at Krishna Pooja Textiles.
                    </p>
                    <div style="display: flex; gap: 15px; margin-bottom: 40px;">
