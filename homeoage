        <a href="#products" onclick="closeMobileMenu()">Products</a>
        <a href="#categories" onclick="closeMobileMenu()">Categories</a>
        <a href="#about" onclick="closeMobileMenu()">About</a>
        <a href="#contact" onclick="closeMobileMenu()">Contact</a>
